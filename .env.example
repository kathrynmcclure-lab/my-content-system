ANTHROPIC_API_KEY=              # Claude API key — get from console.anthropic.com
FIGMA_TOKEN=                    # Figma personal access token — get from figma.com/settings
SITE_PASSWORD=                  # Shared team password for the web app

# Content Audit (Google Sheets export)
GOOGLE_SERVICE_ACCOUNT_EMAIL=   # client_email from your service account JSON
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=  # private_key from your service account JSON
GOOGLE_SHARE_EMAIL=             # Optional — auto-share each audit sheet with this email
